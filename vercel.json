{
  "buildCommand": "npx convex deploy --cmd \"bun run build\" && mkdir -p api && cp dist/server/server.js api/index.js",
  "installCommand": "bun install",
  "outputDirectory": "dist/client",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs22.x"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
